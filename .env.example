# Neon Database Connection
# Get your connection string from https://neon.tech
DATABASE_URL=

# Admin Dashboard Credentials
# WARNING: Use a strong, unique password (min 16 chars, mixed case + numbers + symbols).
# NEVER commit real credentials to git — use environment variables in your host.
# Generate a strong password: openssl rand -base64 24
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_use_a_strong_password_min_16_chars

# NextAuth Secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32
NEXTAUTH_URL=https://your-domain.com
